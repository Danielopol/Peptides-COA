# Keep the build context small + never ship secrets or local artifacts.
# (Only backend/ and Rules/ are COPYed by the Dockerfile, but trimming the
#  context still speeds uploads.)

# Secrets
.env
backend/.env

# Python local artifacts
backend/.venv/
.venv/
**/__pycache__/
*.py[cod]
backend/.pytest_cache/
.pytest_cache/

# The entire Flutter app is not part of the backend image
app/

# Dev assets / sample corpora not needed at runtime
Articles/
COAs/
FAKE/
coa-faker/
*.png
*.xlsx
*.html
Flutter_files/

# Git + editor + tooling
.git/
.idea/
.vscode/
.playwright-mcp/
